{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "@waves-cn",
  "homepage": "https://waves-cn.vercel.app",
  "repository": "https://github.com/Ziane-Badreddine/waves-cn",
  "items": [
    {
      "name": "wave-cn",
      "title": "Wave Core",
      "description": "Core hook, player and shared defaults powering all waves-cn components. Built on wavesurfer.js.",
      "type": "registry:lib",
      "dependencies": ["wavesurfer.js"],
      "files": [
        {
          "type": "registry:lib",
          "path": "src/registry/lib/wave-cn.tsx"
        }
      ]
    },
    {
      "name": "wave-player",
      "title": "Wave Player",
      "description": "Full-featured wave player with play/pause, volume control, seek bar and optional title.",
      "type": "registry:component",
      "dependencies": ["wavesurfer.js", "lucide-react"],
      "registryDependencies": ["@waves-cn/wave-cn"],
      "files": [
        {
          "type": "registry:component",
          "path": "src/registry/components/wave-player.tsx",
          "target": "components/waves-cn/wave-player.tsx"
        }
      ]
    },
    {
      "name": "wave-recorder",
      "title": "Wave Recorder",
      "description": "Voice message recorder with live waveform, pause/resume, discard and auto-stop.",
      "type": "registry:component",
      "dependencies": ["wavesurfer.js", "lucide-react"],
      "registryDependencies": ["@waves-cn/wave-cn"],
      "files": [
        {
          "type": "registry:component",
          "path": "src/registry/components/wave-recorder.tsx",
          "target": "components/waves-cn/wave-recorder.tsx"
        }
      ]
    },
    {
      "name": "wave-speed",
      "title": "Wave Speed",
      "description": "wave player with continuous playback speed control and preserve-pitch toggle.",
      "type": "registry:component",
      "dependencies": ["wavesurfer.js", "lucide-react"],
      "registryDependencies": ["@waves-cn/wave-cn"],
      "files": [
        {
          "type": "registry:component",
          "path": "src/registry/components/wave-speed.tsx",
          "target": "components/waves-cn/wave-speed.tsx"
        }
      ]
    },
    {
      "name": "wave-zoom",
      "title": "Wave Zoom",
      "description": "wave player with mouse-wheel zoom via wavesurfer.js ZoomPlugin.",
      "type": "registry:component",
      "dependencies": ["wavesurfer.js", "lucide-react"],
      "registryDependencies": ["@waves-cn/wave-cn"],
      "files": [
        {
          "type": "registry:component",
          "path": "src/registry/components/wave-zoom.tsx",
          "target": "components/waves-cn/wave-zoom.tsx"
        }
      ]
    },
    {
      "name": "wave-video",
      "title": "Wave Video",
      "description": "Waveform player synced to a video element via the wavesurfer.js media prop.",
      "type": "registry:component",
      "dependencies": ["wavesurfer.js", "lucide-react"],
      "registryDependencies": ["@waves-cn/wave-cn"],
      "files": [
        {
          "type": "registry:component",
          "path": "src/registry/components/wave-video.tsx",
          "target": "components/waves-cn/wave-video.tsx"
        }
      ]
    },
    {
      "name": "wave-timeline",
      "title": "Wave Timeline",
      "description": "wave player with timeline ruler, zoom slider and volume control powered by wavesurfer.js TimelinePlugin.",
      "type": "registry:component",
      "dependencies": ["wavesurfer.js", "lucide-react"],
      "registryDependencies": ["@waves-cn/wave-cn"],
      "files": [
        {
          "type": "registry:component",
          "path": "src/registry/components/wave-timeline.tsx",
          "target": "components/waves-cn/wave-timeline.tsx"
        }
      ]
    }
  ]
}
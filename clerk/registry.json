      "dependencies": [
        "@clerk/nextjs"
      ],
      "registryDependencies": [
        "button"
      ],
      "files": [
        {
          "path": "nextjs/common/header/header.tsx",
          "type": "registry:component"
        }
      ]
    },
    {
      "$schema": "https://ui.shadcn.com/schema/registry-item.json",
      "name": "nextjs-layout-with-header",
      "type": "registry:page",
      "title": "Layout with Header",
      "description": "A root layout component with Clerk provider, theme provider, and header.",
      "dependencies": [
        "@clerk/nextjs",
        "@clerk/ui",
        "next-themes"
      ],
      "registryDependencies": [
        "@clerk/nextjs-clerk-provider",
        "@clerk/nextjs-theme-provider",
        "@clerk/nextjs-header"

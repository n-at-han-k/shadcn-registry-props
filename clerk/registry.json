      "title": "Clerk Next.js Waitlist Page (App Router)",
      "description": "A waitlist page for Next.js App Router with Clerk authentication.",
      "dependencies": [
        "@clerk/nextjs"
      ],
      "files": [
        {
          "path": "nextjs/aio/waitlist-page/page.tsx",
